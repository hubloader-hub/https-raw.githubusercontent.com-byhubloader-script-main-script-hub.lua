local function GetPlayerFromDisplayOrUserName(text)
    text = text:lower()
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():match(text) or p.DisplayName:lower():match(text) then
            return p
        end
    end
    return nil
end

